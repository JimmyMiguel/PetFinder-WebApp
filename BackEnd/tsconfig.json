{
    "compilerOptions": {
      "target": "ES2022",
      "module": "CommonJS",
      "rootDir": "./src",
      "outDir": "./dist",
      "esModuleInterop": true,
      "allowSyntheticDefaultImports": true,
      "strict": true,
       "paths": {
        "@/*": ["./src/*"],
        "@models/*": ["./src/models/*"],
        "@controllers/*": ["./src/controllers/*"]}
    },
    "include": ["src/**/*"],
    "exclude": ["node_modules", "**/*.spec.ts"]
  }
  